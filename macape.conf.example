# macape — home-row modifiers config
# Copy to ~/.config/macape/macape.conf and edit to taste.

hold_timeout_ms = 200
tap_timeout_ms  = 200
max_modifier_hold_ms = 10000

# Per-key override: key = modifier [hold_ms] [tap_ms]
# keycap = modifier
#   modifiers: lcmd rcmd lalt ralt lctl rctl lsft rsft
#              (also: cmd, alt, opt, ctl, ctrl, sft, shift, command, option, control)
A = lcmd
S = lalt
D = lctl
F = lsft
J = rsft
K = rctl
L = ralt
; = rcmd

# Optional arrow layer: hold space, press j/k/l/; for arrows
[layer space]
hold = space
j = left
k = down
l = up
; = right

# Optional one-way key swaps (instant remap)
[swap]
caps_lock = escape
right_command = left_control
